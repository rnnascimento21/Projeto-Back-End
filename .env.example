PORT=3000

DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=14505

# Configuração de e-mail para envio de código 2FA
# O remetente é a conta que envia a mensagem (MAIL_USER / MAIL_PASS).
# O destinatário é o e-mail digitado pelo usuário no formulário.

# Opção 1: Gmail (recomendado com App Password)
MAIL_USER=seuemail@gmail.com
MAIL_PASS=sua_senha_de_app_gmail
# MAIL_FROM="SustentaTech <seuemail@gmail.com>"

# Opção 2: SMTP de outro provedor
# MAIL_HOST=smtp.seudominio.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=contato@seudominio.com
# MAIL_PASS=sua_senha_smtp
# MAIL_FROM="SustentaTech <contato@seudominio.com>"

# IMPORTANTE:
# - Se usar Gmail, crie uma senha de app em https://myaccount.google.com/apppasswords
# - Se usar outro provedor, coloque as configurações SMTP corretas.
# - O código será enviado para qualquer e-mail informado no login/cadastro.
